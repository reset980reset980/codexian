{
  "name": "codexian",
  "version": "0.2.6",
  "description": "Codexian - OpenAI Codex CLI inside Obsidian",
  "main": "main.js",
  "scripts": {
    "build:css": "node scripts/build-css.mjs",
    "dev": "npm run build:css && node esbuild.config.mjs --watch",
    "build": "npm run build:css && tsc --noEmit && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "obsidian",
    "codex",
    "openai",
    "ai"
  ],
  "author": "reallygood83",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.27.1",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
